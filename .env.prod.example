# Baqsy System — production environment template.
# Copy to .env on the server and fill in real values. Never commit the real file.

# --- Django ---
DJANGO_SETTINGS_MODULE=baqsy.settings.prod
DJANGO_SECRET_KEY=REPLACE-WITH-50+CHAR-RANDOM-STRING
DEBUG=False
# Comma-separated. Include the server IP for initial deploy, plus the domain(s).
ALLOWED_HOSTS=78.40.108.112,baqsy.kz,www.baqsy.kz

# Browser origins allowed to call the API (must be full scheme+host).
CORS_ALLOWED_ORIGINS=http://78.40.108.112,https://baqsy.kz,https://www.baqsy.kz
CSRF_TRUSTED_ORIGINS=http://78.40.108.112,https://baqsy.kz,https://www.baqsy.kz

# --- Database ---
POSTGRES_DB=baqsy
POSTGRES_USER=baqsy
POSTGRES_PASSWORD=REPLACE-WITH-STRONG-PASSWORD
DATABASE_URL=postgres://baqsy:REPLACE-WITH-STRONG-PASSWORD@db:5432/baqsy

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
AIOGRAM_REDIS_URL=redis://redis:6379/1
REDIS_HOST=redis
REDIS_PORT=6379

# --- Object storage (MinIO) ---
MINIO_ACCESS_KEY=REPLACE-WITH-RANDOM-KEY
MINIO_SECRET_KEY=REPLACE-WITH-LONG-RANDOM-SECRET
MINIO_BUCKET=baqsy
MINIO_ENDPOINT_URL=http://minio:9000

# --- Bootstrap superuser ---
DJANGO_SUPERUSER_EMAIL=admin@baqsy.kz
DJANGO_SUPERUSER_PASSWORD=REPLACE-WITH-STRONG-PASSWORD

# --- Django↔Bot shared secret (X-Bot-Token header) ---
BOT_API_SECRET=REPLACE-WITH-RANDOM-SECRET

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# --- Site URL used in bot deep-links and admin ---
SITE_URL=http://78.40.108.112

# --- CloudPayments (fill in when going live) ---
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=

# --- WhatsApp provider (Wazzup24 — optional) ---
WAZZUP24_API_KEY=
WAZZUP24_CHANNEL_ID=

# --- Frontend build-time ---
VITE_CLOUDPAYMENTS_PUBLIC_ID=
VITE_API_URL=/api/v1

# --- TLS redirect — flip to True once HTTPS is wired up via certbot ---
SECURE_SSL_REDIRECT=False
